# Use Node.js 20 base image
FROM node:20-slim

# Set working directory
WORKDIR /app

# Copy package.json and package-lock.json
COPY frontend/package*.json ./

# Install dependencies
RUN npm install

# Copy frontend code
COPY frontend/ ./

# Expose port
EXPOSE 5173

# Command to run dev server
CMD ["npm", "run", "dev", "--", "--host", "0.0.0.0"]
